#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/emma/github/express-js-on-vercel/node_modules/.pnpm/jdenticon@3.3.0/node_modules/jdenticon/bin/node_modules:/home/emma/github/express-js-on-vercel/node_modules/.pnpm/jdenticon@3.3.0/node_modules/jdenticon/node_modules:/home/emma/github/express-js-on-vercel/node_modules/.pnpm/jdenticon@3.3.0/node_modules:/home/emma/github/express-js-on-vercel/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/emma/github/express-js-on-vercel/node_modules/.pnpm/jdenticon@3.3.0/node_modules/jdenticon/bin/node_modules:/home/emma/github/express-js-on-vercel/node_modules/.pnpm/jdenticon@3.3.0/node_modules/jdenticon/node_modules:/home/emma/github/express-js-on-vercel/node_modules/.pnpm/jdenticon@3.3.0/node_modules:/home/emma/github/express-js-on-vercel/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/jdenticon@3.3.0/node_modules/jdenticon/bin/jdenticon.js" "$@"
else
  exec node  "$basedir/../.pnpm/jdenticon@3.3.0/node_modules/jdenticon/bin/jdenticon.js" "$@"
fi
